# ========== WISPManager — Variables de entorno ==========

# Base de datos PostgreSQL
DATABASE_URL=postgresql://wisp_user:wisp_pass@localhost:5432/wisp_db

# Seguridad JWT (cambiar en producción — mínimo 32 caracteres)
JWT_SECRET=cambia_esta_clave_secreta_en_produccion_minimo_32chars
JWT_EXPIRES_IN=8h

# Servidor
PORT=4000
NODE_ENV=development

# Frontend (para configuración de CORS)
FRONTEND_URL=http://localhost:3000

# Opcionales
# LOG_LEVEL=debug
# BCRYPT_ROUNDS=12
